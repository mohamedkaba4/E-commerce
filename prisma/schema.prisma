generator client {
  provider      = "prisma-client-js"
  engineType    = "library"  
}

datasource db {
  provider = "postgresql"
}

model Product {
  id    String @id @default(cuid())
  slug  String @unique
  // ... your other product fields
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Categories {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}